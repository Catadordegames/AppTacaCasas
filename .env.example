# ==========================================
# Taça das Casas - Variáveis de Ambiente
# ==========================================
# Copie este arquivo para .env e preencha os valores

# ------------------------------------------
# DATABASE (MariaDB/MySQL)
# ------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=tacadascasas

# ------------------------------------------
# BACKEND (Node.js/Express)
# ------------------------------------------
# Porta onde o backend vai rodar
PORT=3000

# Ambiente: development | production
NODE_ENV=production

# JWT Secret para autenticação (mínimo 32 caracteres)
# Gere uma chave segura com: openssl rand -base64 32
JWT_SECRET=coloque_uma_chave_secreta_longa_aqui_minimo_32_caracteres

# ------------------------------------------
# FRONTEND (React/Vite)
# ------------------------------------------
# URL da API que o frontend vai chamar
# Desenvolvimento: http://localhost:3000
# Produção: https://tacadascasas.duckdns.org
VITE_API_URL=http://localhost:3000
